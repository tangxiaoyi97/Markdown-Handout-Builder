{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tangxiaoyi97.github.io/Markdown-Handout-Builder/book.schema.json",
  "title": "Markdown Handout Builder book configuration",
  "type": "object",
  "required": [
    "title"
  ],
  "oneOf": [
    {
      "required": [
        "chapters"
      ],
      "not": {
        "required": [
          "structure"
        ]
      }
    },
    {
      "required": [
        "structure"
      ],
      "not": {
        "required": [
          "chapters"
        ]
      }
    }
  ],
  "properties": {
    "title": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "number" }
      ]
    },
    "subtitle": {
      "type": [
        "string",
        "number"
      ]
    },
    "language": {
      "type": "string"
    },
    "date": {
      "type": [
        "string",
        "number"
      ]
    },
    "date_format": {
      "type": "string"
    },
    "version": {
      "type": [
        "string",
        "number"
      ]
    },
    "authors": {
      "oneOf": [
        {
          "type": [
            "string",
            "number"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number"
            ]
          }
        }
      ]
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "number"
        ]
      }
    },
    "chapters": {
      "$ref": "#/$defs/rootStructure"
    },
    "structure": {
      "$ref": "#/$defs/rootStructure"
    },
    "layouts": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/layout"
      }
    },
    "output": {
      "$ref": "#/$defs/outputConfig"
    },
    "toc": {
      "$ref": "#/$defs/tocConfig"
    },
    "chapter_toc": {
      "$ref": "#/$defs/chapterTocConfig"
    },
    "pdf": {
      "$ref": "#/$defs/pdfConfig"
    },
    "style": {
      "$ref": "#/$defs/styleConfig"
    },
    "cover": {
      "$ref": "#/$defs/bookCoverConfig"
    },
    "back_cover": {
      "$ref": "#/$defs/bookCoverConfig"
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/themeConfig" }
    },
    "labels": {
      "$ref": "#/$defs/labelsConfig"
    },
    "markdown": {
      "$ref": "#/$defs/markdownConfig"
    },
    "frontmatter": {
      "description": "Dialect-independent frontmatter integration (v3): special rendering, {{fm.*}} placeholders, chapter covers.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title_as_heading": {
          "type": "boolean",
          "description": "Inject fm.title as the h1 of chapters that have none."
        },
        "meta": {
          "oneOf": [
            {
              "const": false
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ],
          "description": "Global default byline keys rendered under each chapter h1 (e.g. [authors, created, modified, tags])."
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Display labels for byline keys, e.g. {created: 创建, modified: 更新}."
        },
        "dates": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fallback_modified": {
              "enum": [
                "none",
                "file"
              ],
              "description": "Use the source file mtime when fm.modified/updated is absent (mtimes are unreliable in CI checkouts)."
            }
          }
        }
      }
    },
    "numbering": {
      "deprecated": true,
      "description": "Removed option; numbering is authored directly in content."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "outputConfig": {
      "type": "object",
      "description": "Optional output paths; omitted fields default to dist/handout.html and dist/handout.pdf.",
      "properties": {
        "html": { "$ref": "#/$defs/nonEmptyString" },
        "pdf": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "tocConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "title": { "type": ["string", "number"], "default": "目录" },
        "depth": { "type": "integer", "minimum": 1, "maximum": 3, "default": 2 }
      },
      "additionalProperties": false
    },
    "chapterTocConfig": {
      "type": "object",
      "properties": {
        "default": { "type": "boolean", "default": false },
        "title": { "type": ["string", "number"], "default": "In this chapter" },
        "depth": { "type": "integer", "minimum": 2, "maximum": 6, "default": 3 },
        "class": { "$ref": "#/$defs/class" }
      },
      "additionalProperties": false
    },
    "slotConfig": {
      "type": "object",
      "properties": {
        "left": { "type": "string" },
        "center": { "type": "string" },
        "right": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pageNumbersConfig": {
      "type": "object",
      "properties": {
        "format": { "type": "string", "default": "{{page}} / {{total}}" },
        "count_cover": { "type": "boolean", "default": true },
        "count_toc": { "type": "boolean", "default": true },
        "count_back_cover": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "pdfConfig": {
      "type": "object",
      "properties": {
        "header_footer": { "type": "boolean", "default": true },
        "toc_page_numbers": { "type": "boolean", "default": true },
        "cover_header_footer": { "type": "boolean", "default": false },
        "page_size": { "$ref": "#/$defs/nonEmptyString", "default": "A4" },
        "margin": {
          "$ref": "#/$defs/nonEmptyString",
          "default": "18mm 16mm 20mm 16mm"
        },
        "date_format": { "$ref": "#/$defs/nonEmptyString" },
        "page_numbers": { "$ref": "#/$defs/pageNumbersConfig" },
        "header": { "$ref": "#/$defs/slotConfig" },
        "footer": { "$ref": "#/$defs/slotConfig" },
        "header_footer_style": { "$ref": "#/$defs/runningStyle" }
      },
      "additionalProperties": false
    },
    "fontsConfig": {
      "type": "object",
      "properties": {
        "body": { "$ref": "#/$defs/nonEmptyString" },
        "heading": { "$ref": "#/$defs/nonEmptyString" },
        "code": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "styleConfig": {
      "type": "object",
      "properties": {
        "accent_color": { "$ref": "#/$defs/nonEmptyString" },
        "content_width": { "$ref": "#/$defs/nonEmptyString" },
        "base_font_size": { "$ref": "#/$defs/nonEmptyString" },
        "print_font_size": { "$ref": "#/$defs/nonEmptyString" },
        "fonts": { "$ref": "#/$defs/fontsConfig" },
        "custom_css": {
          "oneOf": [
            { "$ref": "#/$defs/nonEmptyString" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/nonEmptyString" }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "bookCoverConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "html": { "$ref": "#/$defs/nonEmptyString" },
        "background": { "$ref": "#/$defs/nonEmptyString" },
        "color": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "themeConfig": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
        },
        "label": { "type": "string" },
        "default": { "type": "boolean" },
        "style": { "$ref": "#/$defs/styleConfig" },
        "cover": { "$ref": "#/$defs/bookCoverConfig" },
        "back_cover": { "$ref": "#/$defs/bookCoverConfig" },
        "pdf": { "$ref": "#/$defs/pdfConfig" }
      },
      "additionalProperties": false
    },
    "labelsConfig": {
      "type": "object",
      "propertyNames": {
        "allOf": [
          { "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
          { "not": { "const": "pagebreak" } }
        ]
      },
      "additionalProperties": { "type": "string" }
    },
    "markdownConfig": {
      "type": "object",
      "properties": {
        "dialect": { "enum": ["standard", "obsidian"], "default": "standard" },
        "obsidian": {
          "type": "object",
          "properties": {
            "vault_root": { "$ref": "#/$defs/nonEmptyString", "default": "." },
            "properties": {
              "enum": ["visible", "hidden", "source"],
              "default": "visible"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "class": {
      "type": "string",
      "pattern": "^[A-Za-z_-][A-Za-z0-9_-]*(?:\\s+[A-Za-z_-][A-Za-z0-9_-]*)*$"
    },
    "flow": {
      "type": "object",
      "properties": {
        "break_before": {
          "enum": [
            "auto",
            "page"
          ]
        },
        "break_after": {
          "enum": [
            "auto",
            "page"
          ]
        }
      },
      "additionalProperties": false
    },
    "navigation": {
      "type": "object",
      "properties": {
        "toc": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "outline": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "running": {
      "oneOf": [
        {
          "const": false
        },
        {
          "type": "object",
          "properties": {
            "header": {
              "$ref": "#/$defs/runningBand"
            },
            "footer": {
              "$ref": "#/$defs/runningBand"
            },
            "style": {
              "$ref": "#/$defs/runningStyle"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "runningBand": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "properties": {
            "left": {
              "type": "string"
            },
            "center": {
              "type": "string"
            },
            "right": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "runningStyle": {
      "type": "object",
      "properties": {
        "font_size": {
          "type": "string",
          "minLength": 1
        },
        "color": {
          "type": "string",
          "minLength": 1
        },
        "font_family": {
          "type": "string",
          "minLength": 1
        },
        "offset": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "entryCommon": {
      "type": "object",
      "properties": {
        "class": { "$ref": "#/$defs/class" },
        "layout": { "$ref": "#/$defs/nonEmptyString" },
        "toc": { "type": ["boolean", "string"] },
        "navigation": { "$ref": "#/$defs/navigation" },
        "flow": { "$ref": "#/$defs/flow" },
        "running": { "$ref": "#/$defs/running" }
      }
    },
    "fileCommon": {
      "type": "object",
      "properties": {
        "class": {
          "$ref": "#/$defs/class"
        },
        "layout": {
          "type": "string",
          "minLength": 1
        },
        "chapter_toc": {
          "type": "boolean"
        },
        "toc": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "navigation": {
          "$ref": "#/$defs/navigation"
        },
        "flow": {
          "$ref": "#/$defs/flow"
        },
        "running": {
          "$ref": "#/$defs/running"
        },
        "meta": {
          "$ref": "#/$defs/metaOption"
        },
        "cover": {
          "$ref": "#/$defs/chapterCover"
        }
      }
    },
    "layout": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/fileCommon"
        },
        {
          "type": "object",
          "properties": {
            "extends": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "rootStructure": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "\\.ya?ml$"
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entry"
          }
        }
      ]
    },
    "explicitFile": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/fileCommon"
        },
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "enum": [
                "chapter",
                "insert"
              ]
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "role": {
              "enum": [
                "chapter",
                "insert"
              ]
            },
            "as": {
              "enum": [
                "chapter",
                "insert"
              ]
            }
          },
          "not": { "required": ["role", "as"] }
        }
      ]
    },
    "legacyFile": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/fileCommon"
        },
        {
          "type": "object",
          "required": [
            "path"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "role": {
              "enum": [
                "chapter",
                "insert"
              ]
            },
            "as": {
              "enum": [
                "chapter",
                "insert"
              ]
            }
          },
          "not": { "required": ["role", "as"] }
        }
      ]
    },
    "dividerBody": {
      "allOf": [
        {
          "$ref": "#/$defs/entryCommon"
        },
        {
          "type": "object",
          "properties": {
            "title": {
              "type": [
                "string",
                "number"
              ]
            },
            "subtitle": {
              "type": [
                "string",
                "number"
              ]
            },
            "note": {
              "type": [
                "string",
                "number"
              ]
            },
            "background": {
              "type": "string"
            },
            "color": {
              "type": "string"
            },
            "bleed": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "explicitDivider": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/dividerBody"
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "divider"
            }
          }
        }
      ]
    },
    "legacyDivider": {
      "type": "object",
      "required": [
        "divider"
      ],
      "properties": {
        "divider": {
          "unevaluatedProperties": false,
          "allOf": [{ "$ref": "#/$defs/dividerBody" }]
        }
      },
      "additionalProperties": false
    },
    "blank": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "blank"
          ],
          "properties": {
            "blank": {
              "oneOf": [
                {
                  "const": true
                },
                {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 20
                }
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "blank"
            },
            "count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            },
            "class": {
              "$ref": "#/$defs/class"
            },
            "layout": {
              "type": "string"
            },
            "flow": {
              "$ref": "#/$defs/flow"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "contents": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "contents"
          ],
          "properties": {
            "contents": {
              "const": true
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "contents"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "include": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "include"
          ],
          "properties": {
            "include": {
              "type": "string",
              "pattern": "\\.ya?ml$"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "const": "include"
            },
            "path": {
              "type": "string",
              "pattern": "\\.ya?ml$"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "defaults": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/fileCommon"
        },
        {
          "type": "object"
        }
      ]
    },
    "partBody": {
      "allOf": [
        {
          "$ref": "#/$defs/dividerBody"
        },
        {
          "type": "object",
          "properties": {
            "defaults": {
              "$ref": "#/$defs/defaults"
            },
            "children": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/entry"
              }
            },
            "chapters": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/entry"
              }
            },
            "structure": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/entry"
              }
            }
          },
          "oneOf": [
            {
              "required": [
                "children"
              ]
            },
            {
              "required": [
                "chapters"
              ]
            },
            {
              "required": [
                "structure"
              ]
            }
          ]
        }
      ]
    },
    "explicitPart": {
      "unevaluatedProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/partBody"
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "const": "part"
            }
          }
        }
      ]
    },
    "legacyPart": {
      "type": "object",
      "required": [
        "part"
      ],
      "properties": {
        "part": {
          "unevaluatedProperties": false,
          "allOf": [{ "$ref": "#/$defs/partBody" }]
        }
      },
      "additionalProperties": false
    },
    "entry": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/explicitFile"
        },
        {
          "$ref": "#/$defs/legacyFile"
        },
        {
          "$ref": "#/$defs/explicitDivider"
        },
        {
          "$ref": "#/$defs/legacyDivider"
        },
        {
          "$ref": "#/$defs/blank"
        },
        {
          "$ref": "#/$defs/contents"
        },
        {
          "$ref": "#/$defs/include"
        },
        {
          "$ref": "#/$defs/explicitPart"
        },
        {
          "$ref": "#/$defs/legacyPart"
        }
      ]
    },
    "metaOption": {
      "description": "Chapter byline under the h1: false disables, a list picks frontmatter keys in order; omitted inherits (entry -> defaults/layout -> global frontmatter.meta).",
      "oneOf": [
        {
          "const": false
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "chapterCover": {
      "description": "Per-chapter cover page built from frontmatter (a full page before the chapter).",
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "class": {
              "$ref": "#/$defs/class"
            },
            "background": {
              "type": "string"
            },
            "color": {
              "type": "string"
            },
            "bleed": {
              "type": "boolean",
              "description": "Official PDF paints the cover page edge-to-edge (requires an outline-addressable chapter h1)."
            },
            "title": {
              "type": "string",
              "description": "Template; default {{fm.title}} falling back to the chapter h1."
            },
            "subtitle": {
              "type": "string"
            },
            "meta": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Template lines, e.g. \"更新 {{fm.modified}}\"."
            }
          }
        }
      ]
    }
  }
}
